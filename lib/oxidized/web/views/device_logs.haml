!!!
%html
%head
  %meta{charset: "UTF-8"}
  %meta{name: "viewport", content: "width=device-width, initial-scale=1.0"}
  %title Логи устройства: #{@node_name}
  %link{href: url_for('/css/style.css'), rel: "stylesheet"}
  :css
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #f5f5f5;
      margin: 0;
      padding: 20px;
    }
    .container {
      max-width: 2000px;
      margin: 0 auto;
      background: white;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      padding: 30px;
    }
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
      flex-wrap: wrap;
      gap: 10px;
    }
    h1 {
      color: #333;
      margin: 0;
      font-size: 24px;
    }
    .back-link {
      color: #007bff;
      text-decoration: none;
      font-size: 14px;
    }
    .back-link:hover { text-decoration: underline; }
    .controls {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
      background: #f8f9fa;
      padding: 15px;
      border-radius: 6px;
      margin-bottom: 20px;
    }
    .controls label {
      font-size: 13px;
      color: #555;
      margin-right: 5px;
    }
    .controls select, .controls input {
      padding: 6px 10px;
      border: 1px solid #ddd;
      border-radius: 4px;
      font-size: 13px;
    }
    .btn {
      background: #007bff;
      color: white;
      border: none;
      padding: 8px 16px;
      border-radius: 4px;
      cursor: pointer;
      font-size: 14px;
      font-weight: 500;
    }
    .btn:hover { background: #0056b3; }
    .btn:disabled { background: #ccc; cursor: not-allowed; }
    .btn-secondary { background: #6c757d; }
    .btn-secondary:hover { background: #545b62; }
    .btn-success { background: #28a745; }
    .btn-success:hover { background: #218838; }
    .btn-warning { background: #ffc107; color: #000; }
    .btn-warning:hover { background: #e0a800; }
    .info-panel {
      background: #e7f3ff;
      border-left: 4px solid #007bff;
      padding: 12px 15px;
      border-radius: 4px;
      margin-bottom: 20px;
      font-size: 13px;
    }
    .info-panel strong { color: #0056b3; }
    .log-container {
      background: #1e1e1e;
      color: #d4d4d4;
      border-radius: 6px;
      padding: 15px;
      font-family: 'Courier New', Consolas, monospace;
      font-size: 13px;
      line-height: 1.6 !important;
      max-height: 90vh;
      min-height: 600px;
      overflow-y: auto;
      overflow-x: auto;
      white-space: pre-wrap !important;
      word-wrap: break-word !important;
      word-break: normal !important;
      transition: all 0.3s ease;
    }
    .log-container.fullscreen {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      max-height: 100vh;
      min-height: 100vh;
      z-index: 9999;
      border-radius: 0;
      padding: 20px;
    }
    .status-bar {
      display: flex;
      justify-content: space-between;
      padding: 10px 15px;
      background: #f8f9fa;
      border-radius: 4px;
      margin-top: 15px;
      font-size: 13px;
      color: #666;
    }
    .loading {
      text-align: center;
      padding: 40px;
      color: #666;
    }
    .spinner {
      border: 3px solid #f3f3f3;
      border-top: 3px solid #007bff;
      border-radius: 50%;
      width: 40px;
      height: 40px;
      animation: spin 1s linear infinite;
      margin: 0 auto 15px;
    }
    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
    .error-box {
      background: #f8d7da;
      border: 1px solid #f5c6cb;
      color: #721c24;
      padding: 15px;
      border-radius: 4px;
      margin: 20px 0;
    }
    .auto-refresh {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
      color: #555;
    }
    .auto-refresh input { margin: 0; }
    .close-fullscreen {
      position: absolute;
      top: 10px;
      right: 20px;
      background: #dc3545;
      color: white;
      border: none;
      padding: 8px 16px;
      border-radius: 4px;
      cursor: pointer;
      font-size: 14px;
      z-index: 10000;
      display: none;
    }
    .close-fullscreen:hover { background: #c82333; }
    .log-container.fullscreen + .close-fullscreen {
      display: block;
    }
%body
  .container
    .header
      %h1  Логи устройства: #{@node_name}
      %a.back-link{href: url_for('/nodes')} ← Назад к списку
    .info-panel
      %strong Устройства: #{@node_name} |
      IP: 
      %span#deviceIp загрузка...
      |
      Модель: 
      %span#deviceModel загрузка...
    .controls
      %div
        %label{for: "logType"} Тип логов:
        %select#logType
          %option{value: "system", selected: true} Системные
          %option{value: "security"} Безопасность
          %option{value: "interface"} Интерфейсы
      %div
        %label{for: "linesCount"} Строк:
        %select#linesCount
          %option{value: "50"} 50
          %option{value: "100", selected: true} 100
          %option{value: "200"} 200
          %option{value: "500"} 500
      %button.btn#loadBtn Загрузить
      %button.btn.btn-secondary#copyBtn  Копировать
      %button.btn.btn-warning#fullscreenBtn  Развернуть
      .auto-refresh
        %input#autoRefresh{type: "checkbox"}
        %label{for: "autoRefresh"} Автообновление (30с)
    #logContent.log-container
      .loading
        .spinner
        %div Подключение к устройству...
    %button.close-fullscreen#closeFullscreenBtn  Закрыть
    .status-bar
      %span#statusText Готов к загрузке
      %span#lastUpdate
  :javascript
    document.addEventListener('DOMContentLoaded', function() {
      const nodeName = "#{@node_name}";
      const logContent = document.getElementById('logContent');
      const loadBtn = document.getElementById('loadBtn');
      const copyBtn = document.getElementById('copyBtn');
      const fullscreenBtn = document.getElementById('fullscreenBtn');
      const closeFullscreenBtn = document.getElementById('closeFullscreenBtn');
      const logTypeSelect = document.getElementById('logType');
      const linesCountSelect = document.getElementById('linesCount');
      const autoRefreshCheckbox = document.getElementById('autoRefresh');
      const statusText = document.getElementById('statusText');
      const lastUpdate = document.getElementById('lastUpdate');
      const deviceIp = document.getElementById('deviceIp');
      const deviceModel = document.getElementById('deviceModel');
      
      let autoRefreshInterval = null;
      let currentLogs = [];

      function loadLogs() {
        loadBtn.disabled = true;
        loadBtn.textContent = '⏳ Загрузка...';
        statusText.textContent = 'Подключение по SSH...';
        
        const logType = logTypeSelect.value;
        const lines = linesCountSelect.value;
        
        fetch(`/logs/api/${nodeName}?type=${logType}&lines=${lines}`)
          .then(res => res.json())
          .then(data => {
            if (data.error) {
              logContent.innerHTML = `<div class="error-box">❌ ${escapeHtml(data.error)}</div>`;
              statusText.textContent = 'Ошибка';
            } else {
              currentLogs = data.logs;
              deviceIp.textContent = data.ip;
              deviceModel.textContent = data.model;
              
              renderLogs(data.logs);
              
              statusText.textContent = `Загружено строк: ${data.lines_count}`;
              lastUpdate.textContent = `Последнее обновление: ${data.timestamp}`;
            }
          })
          .catch(err => {
            logContent.innerHTML = `<div class="error-box">❌ Ошибка сети: ${escapeHtml(err.message)}</div>`;
            statusText.textContent = 'Ошибка сети';
          })
          .finally(() => {
            loadBtn.disabled = false;
            loadBtn.textContent = '🔄 Загрузить';
          });
      }

      function renderLogs(logs) {
        if (logs.length === 0) {
          logContent.innerHTML = '<div class="loading">Логи пусты</div>';
          return;
        }
        
        let html = '<div style="line-height: 1.6;">';
        logs.forEach((line, index) => {
          let cssClass = 'log-line';
          const lower = line.toLowerCase();
          
          if (lower.includes('error') || lower.includes('fail') || lower.includes('down')) {
            cssClass += ' error';
          } else if (lower.includes('warning') || lower.includes('warn')) {
            cssClass += ' warning';
          } else if (lower.includes('up') || lower.includes('success') || lower.includes('ok')) {
            cssClass += ' success';
          } else if (lower.includes('info')) {
            cssClass += ' info';
          }
          
          const escapedLine = escapeHtml(line);
          html += `<div class="${cssClass}" style="margin: 2px 0; padding: 2px 0; min-height: 1.4em;">${escapedLine}</div>`;
        });
        html += '</div>';
        logContent.innerHTML = html;
      }

      function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
      }

      function toggleFullscreen() {
        logContent.classList.toggle('fullscreen');
        if (logContent.classList.contains('fullscreen')) {
          fullscreenBtn.textContent = '🗗 Свернуть';
          document.body.style.overflow = 'hidden';
        } else {
          fullscreenBtn.textContent = ' Развернуть';
          document.body.style.overflow = '';
        }
      }

      loadBtn.addEventListener('click', loadLogs);
      
      copyBtn.addEventListener('click', function() {
        if (currentLogs.length === 0) {
          alert('Нет данных для копирования');
          return;
        }
        const text = currentLogs.join('\n');
        navigator.clipboard.writeText(text).then(() => {
          const originalText = copyBtn.textContent;
          copyBtn.textContent = '✅ Скопировано!';
          setTimeout(() => { copyBtn.textContent = originalText; }, 2000);
        });
      });

      fullscreenBtn.addEventListener('click', toggleFullscreen);
      closeFullscreenBtn.addEventListener('click', toggleFullscreen);

      autoRefreshCheckbox.addEventListener('change', function() {
        if (this.checked) {
          autoRefreshInterval = setInterval(loadLogs, 30000);
          statusText.textContent = 'Автообновление включено';
        } else {
          clearInterval(autoRefreshInterval);
          statusText.textContent = 'Автообновление выключено';
        }
      });

      // Закрытие полноэкранного режима по Escape
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && logContent.classList.contains('fullscreen')) {
          toggleFullscreen();
        }
      });

      // Автозагрузка при открытии страницы
      loadLogs();
    });