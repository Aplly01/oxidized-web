!!!
%html
  %head
    %meta{charset: "UTF-8"}
    %meta{name: "viewport", content: "width=device-width, initial-scale=1.0"}
    %title Массовый импорт устройств
    %link{href: url_for('/css/style.css'), rel: "stylesheet", type: "text/css"}
    :css
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: #f5f5f5;
        margin: 0;
        padding: 20px;
      }
      .container {
        max-width: 900px;
        margin: 0 auto;
        background: white;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        padding: 30px;
      }
      h1 {
        color: #333;
        margin-bottom: 10px;
      }
      .back-link {
        color: #007bff;
        text-decoration: none;
        margin-bottom: 20px;
        display: inline-block;
      }
      .back-link:hover {
        text-decoration: underline;
      }
      .info-box {
        background: #e7f3ff;
        border-left: 4px solid #007bff;
        padding: 15px;
        margin: 20px 0;
        border-radius: 4px;
      }
      .info-box h3 {
        margin-top: 0;
        color: #0056b3;
      }
      .info-box code {
        background: #fff;
        padding: 2px 6px;
        border-radius: 3px;
        font-size: 0.9em;
      }
      .form-group {
        margin: 20px 0;
      }
      label {
        display: block;
        margin-bottom: 8px;
        font-weight: 600;
        color: #555;
      }
      input[type="file"] {
        display: block;
        width: 100%;
        padding: 10px;
        border: 2px dashed #ccc;
        border-radius: 4px;
        cursor: pointer;
      }
      input[type="file"]:hover {
        border-color: #007bff;
      }
      .btn {
        background: #007bff;
        color: white;
        border: none;
        padding: 12px 24px;
        border-radius: 4px;
        cursor: pointer;
        font-size: 16px;
        font-weight: 600;
      }
      .btn:hover {
        background: #0056b3;
      }
      .btn:disabled {
        background: #ccc;
        cursor: not-allowed;
      }
      .btn-secondary {
        background: #6c757d;
        margin-left: 10px;
      }
      .btn-secondary:hover {
        background: #545b62;
      }
      #notification {
        margin-top: 20px;
        padding: 15px;
        border-radius: 4px;
        display: none;
      }
      #notification.success {
        background: #d4edda;
        border: 1px solid #c3e6cb;
        color: #155724;
        display: block;
      }
      #notification.error {
        background: #f8d7da;
        border: 1px solid #f5c6cb;
        color: #721c24;
        display: block;
      }
      #notification.warning {
        background: #fff3cd;
        border: 1px solid #ffeaa7;
        color: #856404;
        display: block;
      }
      .error-list {
        margin-top: 10px;
        max-height: 300px;
        overflow-y: auto;
        background: #fff;
        border: 1px solid #f5c6cb;
        border-radius: 4px;
        padding: 10px;
      }
      .error-item {
        padding: 5px 0;
        border-bottom: 1px solid #eee;
        font-size: 0.9em;
      }
      .error-item:last-child {
        border-bottom: none;
      }
      .stats {
        display: flex;
        gap: 20px;
        margin: 15px 0;
      }
      .stat-item {
        background: #f8f9fa;
        padding: 10px 15px;
        border-radius: 4px;
        text-align: center;
      }
      .stat-value {
        font-size: 24px;
        font-weight: bold;
        color: #007bff;
      }
      .stat-label {
        font-size: 12px;
        color: #666;
      }
      table.example {
        width: 100%;
        border-collapse: collapse;
        margin: 10px 0;
        font-size: 0.9em;
      }
      table.example th, table.example td {
        border: 1px solid #ddd;
        padding: 8px;
        text-align: left;
      }
      table.example th {
        background: #f8f9fa;
        font-weight: 600;
      }
      table.example tr:nth-child(even) {
        background: #f9f9f9;
      }
  %body
    .container
      %a.back-link{href: url_for('/nodes')} ← Назад к списку устройств
      
      %h1 📦 Массовый импорт устройств
      
      .info-box
        %h3 Формат CSV файла
        %p Загрузите CSV файл со списком устройств. Формат:
        %code name, ip, model, username, password, enable
        
        %h4 Пример файла:
        %table.example
          %thead
            %tr
              %th name
              %th ip
              %th model
              %th username
              %th password
              %th enable
          %tbody
            %tr
              %td switch-01
              %td 10.10.10.11
              %td cisco
              %td admin
              %td pass123
              %td enable123
            %tr
              %td switch-02
              %td 10.10.10.12
              %td huawei
              %td admin
              %td pass456
              %td enable456
            %tr
              %td router-01
              %td 10.10.10.13
              %td juniper
              %td root
              %td root123
              %td
        
        %p
          %strong Примечания:
          %ul
            %li Первая строка с заголовком будет пропущена автоматически
            %li Пустые строки и строки начинающиеся с <code>#</code> игнорируются
            %li Поля <code>password</code> и <code>enable</code> необязательны
            %li Поддерживаются кодировки UTF-8 и Windows-1251
      
      %form#bulkImportForm{enctype: "multipart/form-data"}
        .form-group
          %label{for: "file"} Выберите CSV файл:
          %input#file{name: "file", type: "file", accept: ".csv,.txt", required: true}
        
        .form-group
          %button.btn{type: "submit", id: "submitBtn"} 📥 Импортировать устройства
          %button.btn.btn-secondary{type: "button", onclick: "history.back()"} Отмена
      
      #notification

    :javascript
      document.addEventListener('DOMContentLoaded', function() {
        const form = document.getElementById('bulkImportForm');
        const notification = document.getElementById('notification');
        const submitBtn = document.getElementById('submitBtn');
        const fileInput = document.getElementById('file');

        if (!form) return;

        form.addEventListener('submit', function(e) {
          e.preventDefault();
          
          const file = fileInput.files[0];
          if (!file) {
            showNotification('Пожалуйста, выберите файл', 'error');
            return;
          }

          submitBtn.disabled = true;
          submitBtn.textContent = '⏳ Загрузка...';
          notification.className = '';
          notification.style.display = 'none';

          const formData = new FormData();
          formData.append('file', file);

          fetch('/nodes/bulk_import', {
            method: 'POST',
            body: formData
          })
          .then(res => res.json())
          .then(data => {
            if (data.error) {
              showNotification('❌ ' + data.error, 'error');
            } else {
              let html = '<strong>✅ ' + data.message + '</strong><br>';
              html += '<div class="stats">';
              html += '<div class="stat-item"><div class="stat-value" style="color: #28a745">' + data.success_count + '</div><div class="stat-label">Успешно</div></div>';
              if (data.error_count > 0) {
                html += '<div class="stat-item"><div class="stat-value" style="color: #dc3545">' + data.error_count + '</div><div class="stat-label">Ошибок</div></div>';
              }
              if (data.skipped_count > 0) {
                html += '<div class="stat-item"><div class="stat-value" style="color: #6c757d">' + data.skipped_count + '</div><div class="stat-label">Пропущено</div></div>';
              }
              html += '</div>';
              
              if (data.errors && data.errors.length > 0) {
                html += '<div class="error-list">';
                data.errors.forEach(function(err) {
                  html += '<div class="error-item">⚠️ ' + err + '</div>';
                });
                html += '</div>';
              }
              
              notification.innerHTML = html;
              notification.className = data.error_count > 0 ? 'warning' : 'success';
              notification.style.display = 'block';
              
              if (data.success_count > 0 && data.error_count === 0) {
                setTimeout(function() {
                  window.location.href = '/nodes';
                }, 2000);
              }
            }
          })
          .catch(err => {
            console.error('Error:', err);
            showNotification('❌ Ошибка сети: ' + err.message, 'error');
          })
          .finally(() => {
            submitBtn.disabled = false;
            submitBtn.textContent = '📥 Импортировать устройства';
          });
        });

        function showNotification(msg, type) {
          notification.textContent = msg;
          notification.className = type;
          notification.style.display = 'block';
          setTimeout(() => {
            notification.style.display = 'none';
          }, 5000);
        }
      });