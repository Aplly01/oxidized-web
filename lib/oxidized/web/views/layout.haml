!!! 5
%html{lang: 'en'}
  !=haml :head
  %body
    %nav.navbar.navbar-expand-lg.bg-body-tertiary.border-bottom.border-secondary-subtle.mb-4
      .container-fluid
        %a.navbar-brand{href: url_for('/')}
          %img{src: url_for('/images/oxidizing_40px.png')}
          Oxidized
        %button.navbar-toggler{type: 'button',
                                  :'data-bs-toggle' => 'collapse',
                                  :'data-bs-target' => '#ox-nav',
                                  :'aria-expanded'  => 'false',
                                  :'aria-label'     => 'Toggle navigation',
                                  :'aria-controls'  => '#ox-nav'}
          %span.navbar-toggler-icon
        .collapse.navbar-collapse#ox-nav
          %ul.navbar-nav.me-auto.mb-1
            %li.nav-item
              %a.nav-link{class: request.path_info == '/nodes/stats' ? 'active' : '',
                            :'aria-current' => request.path_info == '/nodes/stats' ? 'page' : 'false',
                            href: url_for('/nodes/stats')} Stats
            %li.nav-item
              %a.nav-link{href: url_for('/nodes/add')}
                Add
          %form.d-flex{role: 'search',
                      action: url_for('/nodes/conf_search'),
                      method: 'post'}
            %input.form-control.me-2{type: 'text',
                                      name: 'search_in_conf_textbox',
                                      placeholder: 'Search in Configs',
                                      :'aria-label' => 'Search in Configs'}
            %button.btn.btn-primary{type: 'submit'}
              %i.bi.bi-search
          %button.btn.btn-outline-secondary.ms-2#theme-toggle{type: 'button', :'aria-label' => 'Toggle theme'}
            %i.bi.bi-moon-fill
          -# 🔘 Кнопка выхода (показываем только авторизованным)
          - if session[:user]
            %a.btn.btn-outline-danger.ms-2{href: url_for('/logout'), title: 'Выйти из аккаунта'}
              %i.bi.bi-box-arrow-right
              %span.d-none.d-lg-inline.ms-1 Выйти

    .container-fluid
      =yield

    !=haml :footer

    :javascript
      // 🎨 Highlight.js инициализация + переключение темы
      document.addEventListener('DOMContentLoaded', () => {
        // Инициализация подсветки (если библиотека загружена)
        if (typeof hljs !== 'undefined') {
          hljs.highlightAll();
        }

        // Переключение темы highlight.js при смене темы Bootstrap
        const themeToggle = document.getElementById('theme-toggle');
        const hljsTheme = document.getElementById('hljs-theme');
        const LIGHT = '/weblibs/highlight.js/css/github.min.css';
        const DARK = '/weblibs/highlight.js/css/github-dark.min.css';

        function getIsDark() {
          return document.documentElement.getAttribute('data-bs-theme') === 'dark'
            || document.body.classList.contains('dark-mode')
            || window.matchMedia('(prefers-color-scheme: dark)').matches;
        }

        function applyHljsTheme() {
          if (!hljsTheme) return;
          hljsTheme.href = getIsDark() ? DARK : LIGHT;
          // Переподсветка блоков после смены темы
          document.querySelectorAll('code.hljs').forEach(el => {
            if (typeof hljs !== 'undefined') hljs.highlightElement(el);
          });
        }

        // Применить тему при загрузке страницы
        applyHljsTheme();

        // Слушать клик по переключателю темы
        if (themeToggle) {
          themeToggle.addEventListener('click', () => {
            // Небольшая задержка, чтобы Bootstrap успел сменить тему
            setTimeout(applyHljsTheme, 100);
          });
        }

        // Слушать системные изменения темы (если браузер поддерживает)
        if (window.matchMedia) {
          window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', applyHljsTheme);
        }
      });
