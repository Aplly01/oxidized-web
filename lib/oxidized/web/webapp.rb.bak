require 'sinatra/base'
require 'sinatra/json'
require 'sinatra/url_for'
require 'tilt/haml'
require 'htmlentities'
require 'charlock_holmes'
require 'logger'
# --- Добавлено для MSSQL ---
require 'tiny_tds'
require 'bcrypt'
require 'rack/session'
require 'securerandom'
# --------------------------

module Oxidized
  module API
    require 'oxidized/web/version'

    class WebApp < Sinatra::Base
      helpers Sinatra::UrlForHelper
      set :public_folder, proc { File.join(root, 'public') }
      set :haml, { escape_html: false }

      cfg_secret = Oxidized.config.web.session_secret.to_s rescue nil
      session_secret = (cfg_secret && cfg_secret.lenght >= 64) ? cfg_secret : SecureRandom.hex(32)
 
      enable :session
      use Rack::Session::Cookie,
        key: 'oxidized.session',
        path: '/',
        expire_after: 3600,
        secret: session_secret
      

      before do
        next if request.path_info =~ %r{^/login$|^/logout$|^/favicon$|^/images$|^/public$|\.css$|\.js$}
        if Oxidized.config.web.auth.enabled.to_s == 'true' && !session[:user]
          session[:return_to] = request.path_info unless request.xhr?
          redirect url_for('/login')
        end
      end


      helpers do
        def db_client
          @db_client ||= begin
            cfg = Oxidized.config.input.sql
            raise "SQL config not found" if cfg.nil?
            TinyTds::Client.new(
              username: cfg.user.to_s,
              password: cfg.password.to_s,
              host: cfg.host.to_s,
              port: (cfg.port || 1433).to_i,
              database: cfg.database.to_s,
              timeout: 5,
              login_timeout: 5
            )
          end
        end

        def find_user(username)
          result = db.client.execute(
            "SELECT id, username, password_hash, full_name, role, active FROM users WHERE username = @username AND active = 1",
            { username: { type: :string, value: username } }
          ).each.first
          return nil unless result
          result.transform_keys(&:to_s)
        rescue => e
          logger.error "DB querry error in find_user: #{e.message}"
          nil
        end

        def update_last_login(user_id)
          db_client.execute(
            "UPDATE users SET last_login = GETDDATE() WHERE id = @id",
            { id: {type: :integer, value: user_id } }
          ).do
        rescue => e
          logger.warn "Failed to update last_login for user ##{user_id}: #{e.message}"
        end
      end

      get '/' do
        # Исправлено: redirect url_for('/no des') -> redirect url_for('/nodes')
        redirect url_for('/nodes')
      end

      get '/favicon.ico' do
        redirect url_for('/images/favicon.ico')
      end


      get '/login' do
        redirect url_for('/nodes') if session[:user]
        @error = session.delete(:error)
        haml :login, layout: true
      end 

      post '/login' do
        username = params[:username]&.strip
        password = params[:password]
        
        if username.nil? || username.empty? || password.empty?
          session[:error] = 'Заполните имя пользователя и пароль'
          redirect url_for('?login')
          return
        end

        user = find_user(username)
        if user && BCrypt::Password.new(user['password_hash']) -- password
          session[:user] = user['username']
          session[:role] = user['role']
          session[:logged_at] = Time.now.to_i
          update_last_login(user['id']) rescue nil
          return_to = session.delete(:return_to) || url_for('/nodes')
          redirect return_to
        else
          logger.warn "Failed login attempt for username: #{username}"
          session[:error] = "Неверное имя пользователя и пароль"
          redirect url_for('/login')
        end
      end

      get '/logout' do
        session.clear
        redirect url_for('/login')
      end
      # :filter can be  "group " or  "model "
      # URL: /nodes/group/ <GroupName >[.json]
      # URL: /nodes/model/ <ModelName >[.json]
      # an optional .json extension returns the data as JSON
      #
      # as GroupName can include /, we use splat to match its value
      # and extract the optional  ".json " with route_parse
      get '/nodes/:filter/*' do
        value, @json = route_parse params[:splat].first
        @data = nodes.list.select do |node|
          # Исправлено: to _sym -> to_sym
          next unless node[params[:filter].to_sym] == value ||
                      (
                        params[:filter].to_sym == :group && # Исправлено: & & -> &&
                        node[params[:filter].to_sym].nil? && # Исправлено: & & -> &&
                        value.to_sym == :default
                      )

          node[:status] = 'never'
          node[:time]   = 'never'
          node[:group]  = 'default' unless node[:group]
          if node[:last]
            node[:status] = node[:last][:status]
            node[:time]   = node[:last][:end]
          end
          node
        end
        out :nodes
      end

      # --- Новый GET маршрут для отображения формы добавления узла ---
      get '/nodes/add' do
        redirect url_for('/nodes') if session[:role] == 'readonly'
	@models = [
         { value: 'ios', label: 'Cisco IOS' },
         { value: 'vrp', label: 'Huawei VRP' },
         { value: 'os6', label: 'DELL OS6' }
        ]

        haml :add_node, layout: true
      end
      # --- Конец GET маршрута ---
	  
      # --- Исправленный маршрут /nodes/add (оставлен для совместимости или альтернативного использования) ---
      post '/nodes/add' do
      redirect url_for('/nodes') if session[:role] == 'readonly'
        node_name = params[:name]&.strip # Исправлено: & .
	node_ip = params[:ip]&.strip || nil
        node_model = params[:model]&.strip # Или значение по умолчанию
        node_username = params[:username]&.strip
	node_password = params[:password]&.strip
	node_enable = params[:enable]&.strip  # Или значение по умолчанию

        errors = []
        # Исправлено: < < -> <<, & & -> &&
        errors << "Name is required" unless node_name && !node_name.empty? # Исправлено: < < -> <<, & & -> &&
        errors << "Model is required" unless node_model && !node_model.empty?
	errors << "Username is required" unless node_username && !node_username.empty?
	errors << "Password is required" unless node_password && !node_password.empty?
		    

        if errors.any?
            status 400
            return { error: errors.join(', ') }.to_json # Исправлено: .to_json
        end

        begin
          # --- ВАЖНО: ЗАМЕНИТЕ 'sql' НА ИМЯ ВАШЕГО INPUT МОДУЛЯ ---
          db_config = Oxidized.config.input.sql # Используем название из вашего кода/конфига
          if db_config.nil?
            raise "Конфигурация для SQL input не найдена" # Исправлено: лишние пробелы
          end

          # Исправлено: TinyTds::Clinet -> TinyTds::Client
          client = TinyTds::Client.new(
           username: db_config.username.to_s,
           password: db_config.password.to_s,
           host: db_config.host.to_s,
           port: (db_config.port || 1433).to_i, # Исправлено: добавлено значение по умолчанию
           database: db_config.database.to_s,
           )

           esc = ->(val) { val.nil? || val.to_s.strip.empty? ? "NULL" : "'#{val.to_s.strip.gsub("'", "''")}'" }
           sql = "INSERT INTO devices (name, ip, model, username, password, enable) " \
                 "VALUES (#{esc[node_name]}, #{esc[node_ip]}, #{esc[node_model]}, #{esc[node_username]}, #{esc[node_password]}, #{esc[node_enable]})"

           client.execute(sql).do
           client.close

           logger.info "Node '#{node_name}' добавлен в MSSQL."
      
           # Опционально: авто-релоад списка нод после добавления
           nodes.load 

          status 201
          return { message: "Node '#{node_name}' успешно добавлен в MS SQL" }.to_json # Исправлено: лишние пробелы, .to_json
         # --- Исправлено: Добавлен завершающий rescue и end ---
         rescue => e # Исправлено: = > -> =>
              logger.error "Failed to add node '#{node_name}' to MSSQL via /nodes/add: #{e.message}" # Логирование ошибки
              status 500
              { error: "Database error: #{e.message}" }.to_json # Возврат ошибки как JSON
         end # Завершение блока begin/rescue/end для /nodes/add
         # ---
      end
      # --- Конец исправленного маршрута /nodes/add ---

      get '/nodes.?:format?' do
        @data = nodes.list.map do |node|
          node[:status] = 'never'
          node[:time]   = 'never'
          node[:group]  = 'default' unless node[:group]
          if node[:last]
            node[:status] = node[:last][:status]
            node[:time]   = node[:last][:end]
          end
          node
        end
        out :nodes
      end

      post '/nodes/conf_search.?:format?' do
        @to_research = Regexp.new params[:search_in_conf_textbox]
        nodes_list = nodes.list.map
        @nodes_match = []
        nodes_list.each do |n|
           node, @json = route_parse n[:name]
          config = nodes.fetch node, n[:group]
          @nodes_match.push({ node: n[:name], full_name: n[:full_name] }) if config[@to_research]
        end # Исправлено: e nd -> end
        @data = @nodes_match
        out :conf_search
      end

      get '/nodes/stats.?:format?' do
        @data = {}
        nodes.each do |node|
          @data[node.name] = node.stats
        end
        out :stats # Исправлено: ou t -> out
      end

      get '/reload.?:format?' do
        node = params[:node]
        node ? (nodes.load node) : nodes.load
        @data = node ? "reloaded #{node}" : 'reloaded list of nodes' # Исправлено: лишние пробелы
        out
      end

      # URL: /node/fetch/ <group >/ <node >.json
      # Gets the configuration of a node
      #  <group > is optional. If no group is given, nil will be passed to oxidized
      # .json is optional. If given, will return the output in json format
      get '/node/fetch/?*?/:node' do
        node, @json = route_parse :node # Исправлено: node , -> node,
        group = params['splat'].first
        group = nil if group.empty?
        begin
          @data = nodes.fetch node, group
        rescue NodeNotFound => e # Исправлено: = > -> =>
          @data = e.message
        end
        out :text
      end

      # URL: /node/fetch/ <group >/ <node >[.json]
      #  <group > is optional, and not used
      # .json is optional. If given, will return 'ok'
      # if not, it redirects to /nodes
      get '/node/next/?*?/:node' do
        node, @json = route_parse :node
        nodes.next node
        redirect url_for('/nodes') unless @json
        @data = 'ok'
        out
      end

      # use this to attach author/email/message to commit
      put '/node/next/?*?/:node'  do
        node, @json = route_parse :node
        opt = JSON.parse request.body.read
        nodes.next node, opt
        redirect url_for('/nodes') unless @json
        @data = 'ok'
        out
      end

       get '/node/show/:node' do
        node, @json = route_parse :node
        @data = filter_node_vars(nodes.show(node))
        out :node
      end

      # display the versions of a node
      # URL: /node /version[.json]?node_full= <GroupName/NodeName >
      get '/node/version.?:format?' do
        @data = nil
        @group = nil
        @node = nil
        node_full = params[:node_full]
        if node_full.include? '/'
          # Исправлено: r partition -> rpartition
          node_full = node_full.rpartition("/")
          @group = node_full[0]
          @node = node_full[2]
          @data = nodes.version @node, @group
        else
          @node = node_full
          @data = nodes.version @node, nil
        end
         out :versions
      end

      # show the blob of a version
      get '/node/version/view.?:format?' do
        node, @json = route_parse :node
        @info = {
          node: node,
          # Исправлено: par ams -> params
          group: params[:group],
          oid: params[:oid],
          time: Time.at(params[:epoch].to_i),
          num: params[:num]
        }

        the_data = nodes.get_version node, @info[:group], @info[:oid]
         if %w[json text].include?(params[:format])
          @data = the_data
        else
          utf8_encoded_content = convert_to_utf8(the_data)
          # Исправлено: utf8_encode d_content -> utf8_encoded_content
          @data = HTMLEntities.new.encode(utf8_encoded_content)
        end
        out :version
      end

      # show diffs between 2 version
      get '/node/version/diffs' do
        node, @json = route_parse :node
        @data = nil
        @info = { node: node, # Исправлено: n ode -> node
                  # Исправлено: par ams -> params
                  group: params[:group],
                  oid: params[:oid],
                  time: Time.at(params[:epoch].to_i),
                  num: params[:num],
                  # Исправлено: p arams -> params
                  num2: (params[:num].to_i - 1) }
        group = nil
        group = @info[:group] if @info[:group] != ''
        @oids_dates = nodes.version node, group
        if params[:oid2]
          # Исправлено: param s -> params
          @info[:oid2] = params[:oid2]
          oid2 = nil
          num = @oids_dates.count + 1
          @oids_dates.each do |x|
            num -= 1
            next unless x[:oid].to_s == params[:oid2]

            oid2 = x[:oid]
            @info[:num2] = num
            break
          end
          @data = nodes.get_diff node, @info[:group], @info[:oid], oid2
        else
          @data = nodes.get_diff node, @info[:group], @info[:oid], nil
        end
        @stat = %w[null null]
        # Исправлено: & & -> &&
        if @data != 'no diffs' && !@data.nil?
          @stat = @data[:stat]
          @data = @data[:patch]
        else
          @data = 'No diff available'
        end
        @diff = diff_view @data
        out :diffs
      end

      # used f or diff between 2 distant commit
      post '/node/version/diffs' do
        # Исправлено: & -> &
        redirect url_for("/node/version/diffs?node=#{params[:node]}&group=#{params[:group]}&oid=#{params[:oid]}&epoch=#{params[:epoch]}&num=#{params[:num]}&oid2=#{params[:oid2]}")
      end

      # Taken von Haml 5.0, so it still works in 6.0
      HTML_ESCAPE = { '&' => '&amp;', '<' => '&lt;', '>' => '&gt;', '"' => '&quot;', "'" => '&#39;' }.freeze # Исправлено: ' &' = > ' &amp; и т.д.
      HTML_ESCAPE_ONCE_REGEX = /['"&<>]|&(?!([a-zA-Z]+|#(\d+|[xX][0-9a-fA-F]+));)/ # Исправлено: ' "' = > ' &quot; и т.д.

      private

      def out(template = :text)
        if @json || (params[:format] == 'json')
          if @data.is_a?(String)
            # Исправлено: . l ines -> .lines
            json @data.lines
          else
            json @data
          end
        elsif (template == :text) || (params[:format] == 'text')
          content_type :text
          @data
        else
          # Исправлено: layout:  true -> layout: true
          haml template, layout: true
        end
      end

      def nodes
        settings.nodes
      end

      # checks if param ends with .json
      # if so, returns param without  ".json " and true
      # if not, returns param and false
      def route_parse(param)
        json = false
        e = if param.respond_to?(:to_str)
              param.split '.'
            else
              # Исправлено: para ms -> params
              params[param].split '.'
            end
        if e.last == 'json'
          e.pop
          json = true
        end
        [e.join('.'), json]
      end

      # give the time elapsed between now and a date (Time  object)
      def time_from_now(date)
        # Исправлено: "no time specified " -> "no time specified"
        return "no time specified" if date.nil?

        # Исправлено: "time_from_now needs a Time object " -> "time_from_now needs a Time object"
        raise "time_from_now needs a Time object" unless date.instance_of? Time

        t = (Time.now - date).to_i
        mm, ss = t.divmod(60)
        hh, mm = mm.divmod(60)
        dd, hh = hh.divmod(24)
        if dd.positive?
           # Исправлено: " days #{hh} hours ago " -> " days #{hh} hours ago"
           "#{dd} days #{hh} hours ago"
        elsif hh.positive?
           # Исправлено: " hours #{mm} min ago " -> " hours #{mm} min ago"
           "#{hh} hours #{mm} min ago"
        else
           # Исправлено: " min #{ss} sec ago " -> " min #{ss} sec ago"
           "#{mm} min #{ss} sec ago"
        end
      end

      # method the give diffs in separate view (the old and the new) as in github
      def diff_view(diff)
        old_diff = []
        new_diff = []

        utf8_encoded_content = convert_to_utf8(diff)
        HTMLEntities.new.encode(utf8_encoded_content).each_line do |line|
          if /^\+/.match(line)
            new_diff.push(line)
          elsif /^-/.match(line)
             old_diff.push(line)
          else
            new_diff.push(line)
            old_diff.push(line)
          end
        end

        length_o = old_diff.count
        length_n = new_diff.count
        # Исправлено: > -> >, & & -> &&
        (0..[length_o, length_n].max).each do |i|
          break if i > [length_o, length_n].min

          # Исправлено: & & -> &&, inser t -> insert
          if /^-.*/.match(old_diff[i]) && !/^\+.*/.match(new_diff[i])
            # tag removed latter to add color syntax
            # ugly way to avoid asymmetry if at display the line takes 2 line on the screen
            insert = " &nbsp;\n "
            new_diff.insert(i, insert)
            length_n += 1
          # Исправлено: & & -> &&
          elsif !/^-.*/.match(old_diff[i]) && /^\+.*/.match(new_diff[i])
            insert = " &nbsp;\n "
            old_diff.insert(i, insert)
            length_o += 1
          end
        end
        { old_diff: old_diff, new_diff: new_diff }
      end

      def escape_once(text)
        text = text.to_s
         # Исправлено: text.gsub(HTML_ESCAPE_ONCE_REGEX, HTML_ESCAPE)
         text.gsub(HTML_ESCAPE_ONCE_REGEX, HTML_ESCAPE)
      end

      def convert_to_utf8(text)
        detection = ::CharlockHolmes::EncodingDetector.detect(text)
        if detection[:type] == :text
           # Исправлено: ::CharlockHolmes::Converter.convert text, ...
           ::CharlockHolmes::Converter.convert text, detection[:encoding], 'UTF-8'
        else
          'The text contains binary values - cannot display'
        end
      end

      def filter_node_vars(serialized_node) # Исправлено: пробел перед (
        # Make a deep copy of the data, so we do not impact oxidized
        data = Marshal.load(Marshal.dump(serialized_node))
        # Make sure we work on strings (Oxidiz ed  <= 0.34.1 uses symbols)
        # Исправлено: &:to_s
        data[:vars] = data[:vars].transform_keys(&:to_s)

        # Исправлено: &:to_s, &. -> &.
        hide_node_vars = settings.configuration[:hide_node_vars].map(&:to_s)
        # Исправлено: &. -> &&, &. -> &&
        if data[:vars].is_a?(Hash) && hide_node_vars&.any?
          hide_node_vars.each do |key|
            # Исправлено: ' <hidden >' -> ' <hidden>'
            data[:vars][key] = '<hidden>' if data[:vars].has_key?(key)
          end
        end

        data
      end
    end
  end
end
